@model praktika.Models.Product
@{
    ViewData["Title"] = "Редактировать товар";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div style="background:white;border-radius:16px;padding:40px;border:1px solid #f0f0f0;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;">
                <h2 style="font-size:1.2rem;font-weight:600;color:#111;margin:0;">Редактировать товар</h2>
                <a asp-action="Index" style="font-size:12px;color:#999;text-decoration:none;">← Назад</a>
            </div>

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="IdProduct" />
                <input type="hidden" asp-for="ImagePath" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:13px;"></div>

                <div class="mb-3">
                    <div style="display:flex;justify-content:space-between;">
                        <label style="font-size:13px;font-weight:500;color:#333;">Название</label>
                        <span style="font-size:11px;color:#999;">макс. 200 символов</span>
                    </div>
                    <input asp-for="Name" class="form-control mt-1" maxlength="200"
                           style="border-radius:8px;border:1px solid #e0e0e0;padding:10px 14px;" />
                    <span asp-validation-for="Name" class="text-danger" style="font-size:12px;"></span>
                </div>

                <div class="mb-3">
                    <div style="display:flex;justify-content:space-between;">
                        <label style="font-size:13px;font-weight:500;color:#333;">Описание</label>
                        <span style="font-size:11px;color:#999;">макс. 2000 символов</span>
                    </div>
                    <textarea asp-for="Description" class="form-control mt-1" rows="3" maxlength="2000"
                              style="border-radius:8px;border:1px solid #e0e0e0;padding:10px 14px;"></textarea>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;" class="mb-3">
                    <div>
                        <label style="font-size:13px;font-weight:500;color:#333;">Цена (руб)</label>
                        <input asp-for="Price" class="form-control mt-1" maxlength="10"
                               style="border-radius:8px;border:1px solid #e0e0e0;padding:10px 14px;" />
                        <span asp-validation-for="Price" class="text-danger" style="font-size:12px;"></span>
                    </div>
                    <div>
                        <label style="font-size:13px;font-weight:500;color:#333;">Старая цена (руб)</label>
                        <input asp-for="OldPrice" class="form-control mt-1" maxlength="10"
                               style="border-radius:8px;border:1px solid #e0e0e0;padding:10px 14px;" />
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;" class="mb-3">
                    <div>
                        <label style="font-size:13px;font-weight:500;color:#333;">Артикул</label>
                        <input asp-for="Article" class="form-control mt-1" maxlength="50"
                               style="border-radius:8px;border:1px solid #e0e0e0;padding:10px 14px;" />
                    </div>
                    <div>
                        <label style="font-size:13px;font-weight:500;color:#333;">Категория</label>
                        <select asp-for="IdCategory" class="form-control mt-1" asp-items="ViewBag.Categories"
                                style="border-radius:8px;border:1px solid #e0e0e0;padding:10px 14px;">
                            <option value="">Выберите категорию</option>
                        </select>
                    </div>
                </div>

                <!-- ХАРАКТЕРИСТИКИ -->
                <div style="background:#f8f8f8;border-radius:10px;padding:16px;margin-bottom:20px;">
                    <div style="font-size:13px;font-weight:600;color:#111;margin-bottom:14px;">Характеристики</div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                        <div>
                            <label style="font-size:12px;color:#555;">Марка / Производитель</label>
                            <input asp-for="Brand" class="form-control mt-1" maxlength="100"
                                   style="border-radius:6px;border:1px solid #e0e0e0;padding:8px 12px;font-size:13px;" />
                        </div>
                        <div>
                            <label style="font-size:12px;color:#555;">Размер</label>
                            <input asp-for="Size" class="form-control mt-1" maxlength="100"
                                   style="border-radius:6px;border:1px solid #e0e0e0;padding:8px 12px;font-size:13px;" />
                        </div>
                        <div>
                            <label style="font-size:12px;color:#555;">Вес</label>
                            <input asp-for="Weight" class="form-control mt-1" maxlength="100"
                                   style="border-radius:6px;border:1px solid #e0e0e0;padding:8px 12px;font-size:13px;" />
                        </div>
                        <div>
                            <label style="font-size:12px;color:#555;">Материал</label>
                            <input asp-for="Material" class="form-control mt-1" maxlength="100"
                                   style="border-radius:6px;border:1px solid #e0e0e0;padding:8px 12px;font-size:13px;" />
                        </div>
                        <div>
                            <label style="font-size:12px;color:#555;">Цвет</label>
                            <input asp-for="Color" class="form-control mt-1" maxlength="100"
                                   style="border-radius:6px;border:1px solid #e0e0e0;padding:8px 12px;font-size:13px;" />
                        </div>
                        <div>
                            <label style="font-size:12px;color:#555;">Страна производства</label>
                            <input asp-for="Country" class="form-control mt-1" maxlength="100"
                                   style="border-radius:6px;border:1px solid #e0e0e0;padding:8px 12px;font-size:13px;" />
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <div class="mb-3">
                        <label style="font-size:13px;font-weight:500;color:#333;">Текущее фото</label>
                        <div class="mt-1">
                            <img src="@Model.ImagePath" style="width:80px;height:80px;object-fit:cover;border-radius:8px;border:1px solid #f0f0f0;" />
                        </div>
                    </div>
                }

                <div class="mb-3">
                    <label style="font-size:13px;font-weight:500;color:#333;">Новое фото (оставьте пустым чтобы не менять)</label>
                    <input type="file" name="imageFile" accept="image/*" class="form-control mt-1"
                           style="border-radius:8px;border:1px solid #e0e0e0;padding:10px 14px;" />
                </div>

                <div style="display:flex;gap:16px;margin-bottom:20px;">
                    <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:#333;cursor:pointer;">
                        <input asp-for="InStock" type="checkbox" style="width:16px;height:16px;" /> В наличии
                    </label>
                    <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:#333;cursor:pointer;">
                        <input asp-for="IsHit" type="checkbox" style="width:16px;height:16px;" /> Хит продаж
                    </label>
                    <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:#333;cursor:pointer;">
                        <input asp-for="IsNew" type="checkbox" style="width:16px;height:16px;" /> Новинка
                    </label>
                </div>

                <button type="submit" class="btn w-100"
                        style="background:#18181b;color:white;border-radius:8px;padding:12px;font-size:14px;font-weight:500;">
                    Сохранить изменения
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}