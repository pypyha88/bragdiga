@model praktika.Models.Product
@using System.Text.Json
@{
    ViewData["Title"] = Model.Name;
    var specs = new Dictionary<string, string>();
    if (!string.IsNullOrEmpty(Model.Specifications))
    {
        try { specs = JsonSerializer.Deserialize<Dictionary<string, string>>(Model.Specifications) ?? new(); }
        catch { }
    }
}

<div style="margin-bottom:12px;">
    <a asp-action="Index" style="font-size:13px;color:#999;text-decoration:none;">← Назад в каталог</a>
</div>

<div style="display:grid;grid-template-columns:1fr 380px;gap:24px;align-items:start;">

    <!-- ФОТО -->
    <div>
        <div style="background:white;border-radius:16px;border:1px solid #f0f0f0;overflow:hidden;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.ImagePath" style="width:100%;height:100%;object-fit:cover;" />
            }
            else
            {
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="3" width="18" height="18" rx="2" stroke="#ccc" stroke-width="1" />
                    <circle cx="8.5" cy="8.5" r="1.5" fill="#ccc" />
                    <path d="M21 15l-5-5L5 21" stroke="#ccc" stroke-width="1" stroke-linecap="round" />
                </svg>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div style="background:white;border-radius:16px;padding:24px;border:1px solid #f0f0f0;margin-bottom:16px;">
                <h3 style="font-size:1rem;font-weight:600;color:#111;margin-bottom:12px;">Описание</h3>
                <p style="font-size:13px;color:#555;line-height:1.7;margin:0;">@Model.Description</p>
            </div>
        }

        @if (specs.Any())
        {
            <div style="background:white;border-radius:16px;padding:24px;border:1px solid #f0f0f0;">
                <h3 style="font-size:1rem;font-weight:600;color:#111;margin-bottom:16px;">Характеристики</h3>
                <table style="width:100%;border-collapse:collapse;font-size:13px;">
                    @foreach (var spec in specs)
                    {
                        <tr style="border-bottom:1px solid #f5f5f5;">
                            <td style="padding:10px 0;color:#999;width:50%;">@spec.Key</td>
                            <td style="padding:10px 0;color:#111;font-weight:500;">@spec.Value</td>
                        </tr>
                    }
                </table>
            </div>
        }
    </div>

    <!-- КАРТОЧКА ПОКУПКИ -->
    <div style="position:sticky;top:20px;">
        <div style="background:white;border-radius:16px;padding:24px;border:1px solid #f0f0f0;">
            @if (Model.Category != null)
            {
                <div style="font-size:11px;color:#4f8ef7;font-weight:500;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">@Model.Category.Name</div>
            }
            <h1 style="font-size:1.3rem;font-weight:700;color:#111;margin-bottom:8px;line-height:1.3;">@Model.Name</h1>

            @if (!string.IsNullOrEmpty(Model.Article))
            {
                <div style="font-size:12px;color:#999;margin-bottom:16px;">Артикул: @Model.Article</div>
            }

            <div style="display:flex;align-items:baseline;gap:10px;margin-bottom:8px;">
                <span style="font-size:1.8rem;font-weight:700;color:#111;">@Model.Price.ToString("N2") руб</span>
                @if (Model.OldPrice.HasValue)
                {
                    <span style="font-size:1rem;color:#ccc;text-decoration:line-through;">@Model.OldPrice.Value.ToString("N2")</span>
                    <span style="background:#ef4444;color:white;font-size:11px;padding:2px 7px;border-radius:4px;">-@(Math.Round((1 - Model.Price / Model.OldPrice.Value) * 100))%</span>
                }
            </div>

            <div style="margin-bottom:20px;">
                @if (Model.InStock)
                {
                    <span style="background:#f0fdf4;color:#16a34a;font-size:12px;padding:4px 10px;border-radius:4px;">✓ В наличии</span>
                }
                else
                {
                    <span style="background:#fef2f2;color:#dc2626;font-size:12px;padding:4px 10px;border-radius:4px;">✗ Нет в наличии</span>
                }
            </div>

            @if (Model.IsHit)
            {
                <div style="background:#f8f8f8;border-radius:8px;padding:10px 14px;margin-bottom:16px;font-size:12px;color:#555;">
                    🏆 Хит продаж — один из самых популярных товаров
                </div>
            }

            @if (Model.InStock)
            {
                <form asp-controller="Cart" asp-action="Add" method="post">
                    <input type="hidden" name="id" value="@Model.IdProduct" />
                    <input type="hidden" name="returnUrl" value="/Products/Details/@Model.IdProduct" />
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
                        <label style="font-size:12px;color:#555;">Количество:</label>
                        <input type="number" name="quantity" value="1" min="1" max="999"
                               style="width:70px;padding:8px;border:1px solid #e0e0e0;border-radius:6px;font-size:13px;text-align:center;" />
                    </div>
                    <button type="submit" class="btn w-100" style="background:#18181b;color:white;border-radius:8px;padding:12px;font-size:14px;font-weight:500;margin-bottom:8px;">
                        В корзину
                    </button>
                </form>
            }

            <a asp-action="Index" class="btn w-100" style="display:block;text-align:center;background:#f5f5f5;color:#333;border-radius:8px;padding:11px;font-size:13px;text-decoration:none;">
                ← Продолжить покупки
            </a>

            @if (User.IsInRole("Admin"))
            {
                <div style="border-top:1px solid #f0f0f0;margin-top:16px;padding-top:16px;display:flex;gap:8px;">
                    <a asp-action="Edit" asp-route-id="@Model.IdProduct" style="flex:1;text-align:center;background:#f5f5f5;color:#333;padding:8px;border-radius:6px;font-size:12px;text-decoration:none;">Изменить</a>
                    <a asp-action="Delete" asp-route-id="@Model.IdProduct" style="flex:1;text-align:center;background:#fef2f2;color:#dc2626;padding:8px;border-radius:6px;font-size:12px;text-decoration:none;">Удалить</a>
                </div>
            }
        </div>

        <div style="background:white;border-radius:16px;padding:20px;border:1px solid #f0f0f0;margin-top:12px;">
            <div style="font-size:13px;font-weight:600;color:#111;margin-bottom:12px;">Доставка и оплата</div>
            <div style="display:flex;flex-direction:column;gap:8px;">
                <div style="display:flex;align-items:center;gap:10px;font-size:12px;color:#555;">
                    <span>🚚</span> Доставка по городу за 1 день
                </div>
                <div style="display:flex;align-items:center;gap:10px;font-size:12px;color:#555;">
                    <span>🏪</span> Самовывоз из магазина
                </div>
                <div style="display:flex;align-items:center;gap:10px;font-size:12px;color:#555;">
                    <span>💳</span> Оплата картой или наличными
                </div>
                <div style="display:flex;align-items:center;gap:10px;font-size:12px;color:#555;">
                    <span>✅</span> Гарантия качества
                </div>
            </div>
        </div>
    </div>
</div>