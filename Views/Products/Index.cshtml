@model List<praktika.Models.Product>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Каталог товаров";
}

<div style="background:white;border-radius:16px;padding:24px;border:1px solid #f0f0f0;margin-bottom:20px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
        <h2 style="font-size:1.2rem;font-weight:600;color:#111;margin:0;">Каталог товаров</h2>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" style="background:#18181b;color:white;padding:9px 18px;border-radius:8px;font-size:13px;text-decoration:none;">+ Добавить товар</a>
        }
    </div>

    <form asp-action="Index" method="get" style="display:flex;gap:10px;flex-wrap:wrap;">
        <input name="search" value="@ViewBag.Search" placeholder="Поиск по названию или артикулу..."
               style="flex:1;min-width:200px;padding:9px 14px;border:1px solid #e0e0e0;border-radius:8px;font-size:13px;" />

        <select name="categoryId" style="padding:9px 14px;border:1px solid #e0e0e0;border-radius:8px;font-size:13px;min-width:180px;">
            <option value="">Все категории</option>
            @foreach (SelectListItem item in ViewBag.Categories)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>

        <select name="sortBy" style="padding:9px 14px;border:1px solid #e0e0e0;border-radius:8px;font-size:13px;">
            <option value="">Сортировка</option>
            <option value="price_asc" selected="@(ViewBag.SortBy == "price_asc")">Цена ↑</option>
            <option value="price_desc" selected="@(ViewBag.SortBy == "price_desc")">Цена ↓</option>
            <option value="name" selected="@(ViewBag.SortBy == "name")">По названию</option>
        </select>

        <button type="submit" style="background:#4f8ef7;color:white;border:none;padding:9px 20px;border-radius:8px;font-size:13px;cursor:pointer;">Найти</button>
        <a asp-action="Index" style="background:#f5f5f5;color:#666;padding:9px 16px;border-radius:8px;font-size:13px;text-decoration:none;">Сбросить</a>
    </form>
</div>

@if (!Model.Any())
{
    <div style="background:white;border-radius:16px;padding:60px;text-align:center;color:#999;border:1px solid #f0f0f0;">
        <div style="font-size:2rem;margin-bottom:12px;">🔍</div>
        <div style="font-size:14px;">Товары не найдены</div>
    </div>
}
else
{
    <div style="background:white;border-radius:16px;border:1px solid #f0f0f0;overflow:hidden;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
            <thead>
                <tr style="background:#f8f8f8;border-bottom:1px solid #f0f0f0;">
                    <th style="padding:12px 16px;text-align:left;font-weight:600;color:#555;">Фото</th>
                    <th style="padding:12px 16px;text-align:left;font-weight:600;color:#555;">Название</th>
                    <th style="padding:12px 16px;text-align:left;font-weight:600;color:#555;">Артикул</th>
                    <th style="padding:12px 16px;text-align:left;font-weight:600;color:#555;">Категория</th>
                    <th style="padding:12px 16px;text-align:left;font-weight:600;color:#555;">Цена</th>
                    <th style="padding:12px 16px;text-align:left;font-weight:600;color:#555;">Наличие</th>
                    <th style="padding:12px 16px;text-align:left;font-weight:600;color:#555;">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr style="border-bottom:1px solid #f5f5f5;">
                        <td style="padding:10px 16px;">
                            @if (!string.IsNullOrEmpty(p.ImagePath))
                            {
                                <img src="@p.ImagePath" style="width:48px;height:48px;object-fit:cover;border-radius:6px;" />
                            }
                            else
                            {
                                <div style="width:48px;height:48px;background:#f5f5f5;border-radius:6px;display:flex;align-items:center;justify-content:center;">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                        <rect x="3" y="3" width="18" height="18" rx="2" stroke="#ccc" stroke-width="1.2" />
                                        <circle cx="8.5" cy="8.5" r="1.5" fill="#ccc" />
                                        <path d="M21 15l-5-5L5 21" stroke="#ccc" stroke-width="1.2" stroke-linecap="round" />
                                    </svg>
                                </div>
                            }
                        </td>
                        <td style="padding:10px 16px;font-weight:500;color:#111;">
                            @p.Name
                            @if (p.IsHit)
                            {
                                <span style="background:#18181b;color:white;font-size:9px;padding:1px 5px;border-radius:3px;margin-left:4px;">ХИТ</span>
                            }
                            @if (p.IsNew)
                            {
                                <span style="background:#4f8ef7;color:white;font-size:9px;padding:1px 5px;border-radius:3px;margin-left:4px;">NEW</span>
                            }
                        </td>
                        <td style="padding:10px 16px;color:#999;">@p.Article</td>
                        <td style="padding:10px 16px;color:#666;">@p.Category?.Name</td>
                        <td style="padding:10px 16px;">
                            <span style="font-weight:600;color:#111;">@p.Price.ToString("N2") руб</span>
                            @if (p.OldPrice.HasValue)
                            {
                                <span style="color:#ccc;text-decoration:line-through;font-size:11px;margin-left:4px;">@p.OldPrice.Value.ToString("N2")</span>
                            }
                        </td>
                        <td style="padding:10px 16px;">
                            @if (p.InStock)
                            {
                                <span style="background:#f0fdf4;color:#16a34a;font-size:11px;padding:3px 8px;border-radius:4px;">В наличии</span>
                            }
                            else
                            {
                                <span style="background:#fef2f2;color:#dc2626;font-size:11px;padding:3px 8px;border-radius:4px;">Нет</span>
                            }
                        </td>
                        <td style="padding:10px 16px;">
                            <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                @if (p.InStock)
                                {
                                    <form asp-controller="Cart" asp-action="Add" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@p.IdProduct" />
                                        <button type="submit" style="background:#4f8ef7;color:white;border:none;padding:5px 12px;border-radius:6px;font-size:12px;cursor:pointer;">В корзину</button>
                                    </form>
                                }
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@p.IdProduct" style="background:#f5f5f5;color:#333;padding:5px 12px;border-radius:6px;font-size:12px;text-decoration:none;">Изменить</a>
                                    <a asp-action="Delete" asp-route-id="@p.IdProduct" style="background:#fef2f2;color:#dc2626;padding:5px 12px;border-radius:6px;font-size:12px;text-decoration:none;">Удалить</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}