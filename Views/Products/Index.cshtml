@model List<praktika.Models.Product>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Каталог товаров";
}

<!-- ПОИСК И ФИЛЬТРЫ -->
<div style="background:white;border-radius:16px;padding:24px;border:1px solid #f0f0f0;margin-bottom:20px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
        <h2 style="font-size:1.2rem;font-weight:600;color:#111;margin:0;">Каталог товаров</h2>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" style="background:#18181b;color:white;padding:9px 18px;border-radius:8px;font-size:13px;text-decoration:none;">+ Добавить товар</a>
        }
    </div>

    <form asp-action="Index" method="get" style="display:flex;gap:10px;flex-wrap:wrap;">
        <input name="search" value="@ViewBag.Search" placeholder="Поиск по названию или артикулу..."
               style="flex:1;min-width:200px;padding:9px 14px;border:1px solid #e0e0e0;border-radius:8px;font-size:13px;" />

        <select name="categoryId" style="padding:9px 14px;border:1px solid #e0e0e0;border-radius:8px;font-size:13px;min-width:180px;">
            <option value="">Все категории</option>
            @foreach (SelectListItem item in ViewBag.Categories)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>

        <select name="sortBy" style="padding:9px 14px;border:1px solid #e0e0e0;border-radius:8px;font-size:13px;">
            <option value="">Сортировка</option>
            <option value="price_asc" selected="@(ViewBag.SortBy == "price_asc")">Цена ↑</option>
            <option value="price_desc" selected="@(ViewBag.SortBy == "price_desc")">Цена ↓</option>
            <option value="name" selected="@(ViewBag.SortBy == "name")">По названию</option>
        </select>

        <button type="submit" style="background:#4f8ef7;color:white;border:none;padding:9px 20px;border-radius:8px;font-size:13px;cursor:pointer;">Найти</button>
        <a asp-action="Index" style="background:#f5f5f5;color:#666;padding:9px 16px;border-radius:8px;font-size:13px;text-decoration:none;">Сбросить</a>
    </form>
</div>

@if (!Model.Any())
{
    <div style="background:white;border-radius:16px;padding:60px;text-align:center;color:#999;border:1px solid #f0f0f0;">
        <div style="font-size:2rem;margin-bottom:12px;">🔍</div>
        <div style="font-size:14px;">Товары не найдены</div>
    </div>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:20px;">
        @foreach (var p in Model)
        {
            <div style="background:white;border:1px solid #f0f0f0;border-radius:12px;overflow:hidden;">

                <!-- Кликабельная картинка -->
                <a asp-action="Details" asp-route-id="@p.IdProduct"
                   style="display:block;position:relative;aspect-ratio:4/3;background:#f5f5f5;overflow:hidden;text-decoration:none;">
                    @if (!string.IsNullOrEmpty(p.ImagePath))
                    {
                        <img src="@p.ImagePath" style="width:100%;height:100%;object-fit:cover;" />
                    }
                    else
                    {
                        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                                <rect x="3" y="3" width="18" height="18" rx="2" stroke="#ccc" stroke-width="1.2" />
                                <circle cx="8.5" cy="8.5" r="1.5" fill="#ccc" />
                                <path d="M21 15l-5-5L5 21" stroke="#ccc" stroke-width="1.2" stroke-linecap="round" />
                            </svg>
                        </div>
                    }
                    @if (p.IsHit)
                    {
                        <span style="position:absolute;top:8px;left:8px;background:#18181b;color:white;font-size:9px;font-weight:500;padding:2px 7px;border-radius:4px;">ХИТ</span>
                    }
                    @if (p.IsNew)
                    {
                        <span style="position:absolute;top:8px;left:8px;background:#4f8ef7;color:white;font-size:9px;font-weight:500;padding:2px 7px;border-radius:4px;">NEW</span>
                    }
                    @if (p.OldPrice.HasValue)
                    {
                        <span style="position:absolute;top:8px;right:8px;background:#ef4444;color:white;font-size:9px;font-weight:500;padding:2px 7px;border-radius:4px;">
                            -@(Math.Round((1 - p.Price / p.OldPrice.Value) * 100))%
                        </span>
                    }
                </a>

                <div style="padding:14px;">
                    @if (p.Category != null)
                    {
                        <div style="font-size:9px;color:#4f8ef7;font-weight:500;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">@p.Category.Name</div>
                    }

                    <!-- Кликабельное название -->
                    <a asp-action="Details" asp-route-id="@p.IdProduct"
                       style="font-size:13px;font-weight:600;color:#111;margin-bottom:4px;line-height:1.35;min-height:36px;display:block;text-decoration:none;">@p.Name</a>

                    @if (!string.IsNullOrEmpty(p.Article))
                    {
                        <div style="font-size:10px;color:#999;margin-bottom:10px;">Арт: @p.Article · @(p.InStock ? "В наличии" : "Нет в наличии")</div>
                    }
                    <div style="display:flex;justify-content:space-between;align-items:center;padding-top:10px;border-top:1px solid #f0f0f0;">
                        <div>
                            <span style="font-size:15px;font-weight:600;color:#111;">@p.Price.ToString("N2") руб</span>
                            @if (p.OldPrice.HasValue)
                            {
                                <span style="font-size:10px;color:#ccc;text-decoration:line-through;margin-left:4px;">@p.OldPrice.Value.ToString("N2")</span>
                            }
                        </div>
                        @if (p.InStock)
                        {
                            <form asp-controller="Cart" asp-action="Add" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@p.IdProduct" />
                                <input type="hidden" name="returnUrl" value="/Products" />
                                <button type="submit" style="background:#18181b;color:white;border:none;padding:7px 14px;border-radius:6px;font-size:11px;cursor:pointer;">В корзину</button>
                            </form>
                        }
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <div style="display:flex;gap:6px;margin-top:8px;padding-top:8px;border-top:1px solid #f5f5f5;">
                            <a asp-action="Edit" asp-route-id="@p.IdProduct" style="flex:1;text-align:center;background:#f5f5f5;color:#333;padding:5px;border-radius:6px;font-size:11px;text-decoration:none;">Изменить</a>
                            <a asp-action="Delete" asp-route-id="@p.IdProduct" style="flex:1;text-align:center;background:#fef2f2;color:#dc2626;padding:5px;border-radius:6px;font-size:11px;text-decoration:none;">Удалить</a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}