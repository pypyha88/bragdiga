@model praktika.Models.User
@{
    ViewData["Title"] = "Детали пользователя";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div style="background:white;border-radius:16px;padding:40px;border:1px solid #f0f0f0;">

            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;">
                <h2 style="font-size:1.2rem;font-weight:600;color:#111;margin:0;">Детали пользователя</h2>
                <a asp-action="Index" style="font-size:12px;color:#999;text-decoration:none;">← Назад</a>
            </div>

            <div style="text-align:center;margin-bottom:24px;">
                <div style="width:64px;height:64px;background:#f0f4ff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.6rem;margin:0 auto 12px;">👤</div>
                <div style="font-size:1.1rem;font-weight:600;color:#111;">@Model.Login</div>
                <div style="font-size:12px;color:#999;margin-top:4px;">@Model.Role?.Name</div>
            </div>

            <div style="border-top:1px solid #f0f0f0;padding-top:20px;">
                <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #f5f5f5;">
                    <span style="font-size:13px;color:#999;">Логин</span>
                    <span style="font-size:13px;font-weight:500;color:#111;">@Model.Login</span>
                </div>
                <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #f5f5f5;">
                    <span style="font-size:13px;color:#999;">Email</span>
                    <span style="font-size:13px;font-weight:500;color:#111;">@(Model.Email ?? "—")</span>
                </div>
                <div style="display:flex;justify-content:space-between;padding:10px 0;">
                    <span style="font-size:13px;color:#999;">Роль</span>
                    <span style="background:@(Model.Role?.Name == "Admin" ? "#18181b" : "#f0f4ff");color:@(Model.Role?.Name == "Admin" ? "white" : "#4f8ef7");font-size:11px;padding:3px 10px;border-radius:4px;font-weight:500;">
                        @Model.Role?.Name
                    </span>
                </div>
            </div>

            <div style="display:flex;gap:10px;margin-top:24px;">
                <a asp-action="Edit" asp-route-id="@Model?.IdUser"
                   class="btn w-50" style="background:#f5f5f5;color:#333;border-radius:8px;padding:10px;font-size:13px;text-align:center;text-decoration:none;">
                    Изменить
                </a>
                <a asp-action="Index"
                   class="btn w-50" style="background:#18181b;color:white;border-radius:8px;padding:10px;font-size:13px;text-align:center;text-decoration:none;">
                    К списку
                </a>
            </div>
        </div>
    </div>
</div>