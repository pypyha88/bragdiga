@model IEnumerable<praktika.Models.User>
@{
    ViewData["Title"] = "Пользователи";
}

<div style="background:white;border-radius:16px;padding:24px;border:1px solid #f0f0f0;margin-bottom:20px;">
    <div style="display:flex;justify-content:space-between;align-items:center;">
        <h2 style="font-size:1.2rem;font-weight:600;color:#111;margin:0;">Пользователи</h2>
        <a asp-action="Create" style="background:#18181b;color:white;padding:9px 18px;border-radius:8px;font-size:13px;text-decoration:none;">+ Добавить пользователя</a>
    </div>
</div>

<div style="background:white;border-radius:16px;border:1px solid #f0f0f0;overflow:hidden;">
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
            <tr style="background:#f8f8f8;border-bottom:1px solid #f0f0f0;">
                <th style="padding:12px 16px;text-align:left;font-weight:600;color:#555;">Логин</th>
                <th style="padding:12px 16px;text-align:left;font-weight:600;color:#555;">Email</th>
                <th style="padding:12px 16px;text-align:left;font-weight:600;color:#555;">Роль</th>
                <th style="padding:12px 16px;text-align:left;font-weight:600;color:#555;">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr style="border-bottom:1px solid #f5f5f5;">
                    <td style="padding:12px 16px;font-weight:500;color:#111;">@item.Login</td>
                    <td style="padding:12px 16px;color:#666;">@item.Email</td>
                    <td style="padding:12px 16px;">
                        <span style="background:@(item.Role?.Name == "Admin" ? "#18181b" : "#f0f4ff");color:@(item.Role?.Name == "Admin" ? "white" : "#4f8ef7");font-size:11px;padding:3px 10px;border-radius:4px;font-weight:500;">
                            @item.Role?.Name
                        </span>
                    </td>
                    <td style="padding:12px 16px;">
                        <div style="display:flex;gap:6px;">
                            <a asp-action="Edit" asp-route-id="@item.IdUser" style="background:#f5f5f5;color:#333;padding:5px 12px;border-radius:6px;font-size:12px;text-decoration:none;">Изменить</a>
                            <a asp-action="Details" asp-route-id="@item.IdUser" style="background:#f0f4ff;color:#4f8ef7;padding:5px 12px;border-radius:6px;font-size:12px;text-decoration:none;">Детали</a>
                            <a asp-action="Delete" asp-route-id="@item.IdUser" style="background:#fef2f2;color:#dc2626;padding:5px 12px;border-radius:6px;font-size:12px;text-decoration:none;">Удалить</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>