@model praktika.Models.User
@{
    ViewData["Title"] = "Удалить пользователя";
    var roleBg = Model.Role?.Name == "Admin" ? "#18181b" : "#f0f4ff";
    var roleColor = Model.Role?.Name == "Admin" ? "white" : "#4f8ef7";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div style="background:white;border-radius:16px;padding:40px;border:1px solid #f0f0f0;text-align:center;">

            <div style="font-size:2.5rem;margin-bottom:16px;">⚠️</div>
            <h2 style="font-size:1.2rem;font-weight:600;color:#111;margin-bottom:8px;">Удалить пользователя?</h2>
            <p style="color:#999;font-size:13px;margin-bottom:24px;">Это действие нельзя отменить</p>

            <div style="background:#f8f8f8;border-radius:10px;padding:16px;margin-bottom:24px;text-align:left;">
                <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f0f0f0;">
                    <span style="font-size:12px;color:#999;">Логин</span>
                    <span style="font-size:12px;font-weight:500;color:#111;">@Model.Login</span>
                </div>
                <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f0f0f0;">
                    <span style="font-size:12px;color:#999;">Email</span>
                    <span style="font-size:12px;font-weight:500;color:#111;">@(Model.Email ?? "—")</span>
                </div>
                <div style="display:flex;justify-content:space-between;padding:8px 0;">
                    <span style="font-size:12px;color:#999;">Роль</span>
                    <span style="background:@roleBg;color:@roleColor;font-size:11px;padding:3px 10px;border-radius:4px;font-weight:500;">
                        @Model.Role?.Name
                    </span>
                </div>
            </div>

            <form asp-action="Delete" style="display:flex;gap:10px;">
                <input type="hidden" asp-for="IdUser" />
                <a asp-action="Index" class="btn w-50" style="background:#f5f5f5;color:#333;border-radius:8px;padding:11px;font-size:13px;text-decoration:none;">Отмена</a>
                <button type="submit" class="btn w-50" style="background:#dc2626;color:white;border-radius:8px;padding:11px;font-size:13px;">Удалить</button>
            </form>
        </div>
    </div>
</div>