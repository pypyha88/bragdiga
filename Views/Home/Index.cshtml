@using praktika.Models
@{
    ViewData["Title"] = "Главная";
    var products = ViewBag.Products as List<Product> ?? new List<Product>();
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

<!-- HERO -->
<div style="background:#18181b;border-radius:16px;padding:48px 48px;margin-bottom:20px;display:flex;justify-content:space-between;align-items:center;">
    <div>
        <div style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-bottom:12px;">Весенняя акция 2026</div>
        <h1 style="font-size:2.2rem;font-weight:500;color:white;line-height:1.2;margin-bottom:12px;">Всё для строительства<br>и <span style="color:#4f8ef7;">ремонта</span></h1>
        <p style="color:rgba(255,255,255,0.5);margin-bottom:28px;font-size:0.95rem;">Качественные стройматериалы с доставкой.<br>Скидки до 30% на популярные позиции.</p>
        <div style="display:flex;gap:10px;">
            <a href="#catalog" style="background:#4f8ef7;color:white;padding:12px 24px;border-radius:8px;font-weight:500;text-decoration:none;font-size:0.9rem;">Перейти в каталог</a>
            <a href="#" style="background:rgba(255,255,255,0.07);color:rgba(255,255,255,0.7);border:1px solid rgba(255,255,255,0.12);padding:12px 24px;border-radius:8px;font-weight:500;text-decoration:none;font-size:0.9rem;">Акции →</a>
        </div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:3px;width:320px;height:200px;border-radius:12px;overflow:hidden;flex-shrink:0;">
        @for (int i = 0; i < 4; i++)
        {
            var colors = new[] { "#1e2d45", "#172338", "#1c3040", "#142030" };
            <div style="background:@colors[i];display:flex;align-items:center;justify-content:center;opacity:0.9;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="3" width="18" height="18" rx="2" stroke="rgba(255,255,255,0.2)" stroke-width="1.2" />
                    <circle cx="8.5" cy="8.5" r="1.5" fill="rgba(255,255,255,0.2)" />
                    <path d="M21 15l-5-5L5 21" stroke="rgba(255,255,255,0.2)" stroke-width="1.2" stroke-linecap="round" />
                </svg>
            </div>
        }
    </div>
</div>

<!-- ПРЕИМУЩЕСТВА -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:28px;">
    @foreach (var item in new[] {
        ("🚚", "Доставка за 1 день", "По городу и области"),
        ("✅", "Гарантия качества", "Сертифицированная продукция"),
        ("💰", "Оптовые цены", "Скидки от объёма заказа"),
        ("📞", "Поддержка 24/7", "Бесплатная консультация")
        })
    {
        <div style="background:white;border:1px solid #f0f0f0;border-radius:10px;padding:16px;display:flex;align-items:center;gap:12px;">
            <div style="width:36px;height:36px;background:#f5f5f5;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;">@item.Item1</div>
            <div>
                <div style="font-size:13px;font-weight:500;color:#111;margin-bottom:2px;">@item.Item2</div>
                <div style="font-size:11px;color:#999;">@item.Item3</div>
            </div>
        </div>
    }
</div>

<!-- КАТЕГОРИИ -->
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;" id="catalog">
    <h2 style="font-size:1.1rem;font-weight:500;color:#111;margin:0;">Категории</h2>
    <a href="#" style="font-size:12px;color:#4f8ef7;text-decoration:none;">Все категории →</a>
</div>

@if (categories.Any())
{
    <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:8px;margin-bottom:28px;">
        @foreach (var cat in categories)
        {
            <a href="#" style="background:white;border:1px solid #f0f0f0;border-radius:10px;padding:14px 8px;text-align:center;text-decoration:none;display:block;">
                <div style="width:100%;aspect-ratio:1;background:#f5f5f5;border-radius:8px;margin-bottom:8px;"></div>
                <div style="font-size:10px;font-weight:500;color:#111;">@cat.Name</div>
            </a>
        }
    </div>
}
else
{
    <div style="background:#f5f5f5;border-radius:10px;padding:20px;text-align:center;color:#999;font-size:13px;margin-bottom:28px;">
        Категории пока не добавлены
    </div>
}

<!-- ТОВАРЫ -->
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
    <h2 style="font-size:1.1rem;font-weight:500;color:#111;margin:0;">Популярные товары</h2>
</div>

@if (products.Any())
{
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:28px;">
        @foreach (var p in products)
        {
            <div style="background:white;border:1px solid #f0f0f0;border-radius:12px;overflow:hidden;">
                <div style="position:relative;aspect-ratio:4/3;background:#f5f5f5;overflow:hidden;">
                    @if (!string.IsNullOrEmpty(p.ImagePath))
                    {
                        <img src="@p.ImagePath" style="width:100%;height:100%;object-fit:cover;" />
                    }
                    else
                    {
                        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                                <rect x="3" y="3" width="18" height="18" rx="2" stroke="#ccc" stroke-width="1.2" />
                                <circle cx="8.5" cy="8.5" r="1.5" fill="#ccc" />
                                <path d="M21 15l-5-5L5 21" stroke="#ccc" stroke-width="1.2" stroke-linecap="round" />
                            </svg>
                        </div>
                    }
                    @if (p.IsHit)
                    {
                        <span style="position:absolute;top:8px;left:8px;background:#18181b;color:white;font-size:9px;font-weight:500;padding:2px 7px;border-radius:4px;">ХИТ</span>
                    }
                    @if (p.OldPrice.HasValue)
                    {
                        <span style="position:absolute;top:8px;right:8px;background:#ef4444;color:white;font-size:9px;font-weight:500;padding:2px 7px;border-radius:4px;">
                            -@(Math.Round((1 - p.Price / p.OldPrice.Value) * 100))%
                        </span>
                    }
                </div>
                <div style="padding:12px;">
                    @if (p.Category != null)
                    {
                        <div style="font-size:9px;color:#4f8ef7;font-weight:500;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">@p.Category.Name</div>
                    }
                    <div style="font-size:12px;font-weight:500;color:#111;margin-bottom:4px;line-height:1.35;min-height:30px;">@p.Name</div>
                    @if (!string.IsNullOrEmpty(p.Article))
                    {
                        <div style="font-size:10px;color:#999;margin-bottom:8px;">Арт: @p.Article · @(p.InStock ? "В наличии" : "Нет в наличии")</div>
                    }
                    <div style="display:flex;justify-content:space-between;align-items:center;padding-top:8px;border-top:1px solid #f0f0f0;">
                        <div>
                            <span style="font-size:14px;font-weight:500;color:#111;">@p.Price.ToString("N2") руб</span>
                            @if (p.OldPrice.HasValue)
                            {
                                <span style="font-size:10px;color:#ccc;text-decoration:line-through;margin-left:4px;">@p.OldPrice.Value.ToString("N2")</span>
                            }
                        </div>
                        <button style="background:#18181b;color:white;border:none;padding:6px 12px;border-radius:6px;font-size:10px;cursor:pointer;">В корзину</button>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div style="background:#f5f5f5;border-radius:10px;padding:40px;text-align:center;color:#999;font-size:13px;margin-bottom:28px;">
        Товары пока не добавлены — добавьте их через админку
    </div>
}

<!-- CTA -->
<div style="background:#f8f8f8;border:1px solid #f0f0f0;border-radius:14px;padding:32px 40px;display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
    <div>
        <h3 style="font-size:1rem;font-weight:500;color:#111;margin-bottom:6px;">Нужна консультация специалиста?</h3>
        <p style="font-size:12px;color:#999;margin:0;">Поможем подобрать материалы и рассчитаем смету — бесплатно</p>
    </div>
    <a href="tel:+375291234567" style="background:#18181b;color:white;padding:12px 24px;border-radius:8px;font-size:12px;font-weight:500;text-decoration:none;white-space:nowrap;">📞 +375 29 123-45-67</a>
</div>