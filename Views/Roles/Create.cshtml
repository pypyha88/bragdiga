@model praktika.Models.Role
@{
    ViewData["Title"] = "Создать роль";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div style="background:white;border-radius:16px;padding:40px;border:1px solid #f0f0f0;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;">
                <h2 style="font-size:1.2rem;font-weight:600;color:#111;margin:0;">Создать роль</h2>
                <a asp-action="Index" style="font-size:12px;color:#999;text-decoration:none;">← Назад</a>
            </div>

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:13px;"></div>

                <div class="mb-4">
                    <label style="font-size:13px;font-weight:500;color:#333;">Название роли</label>
                    <input asp-for="Name" class="form-control mt-1" placeholder="Например: Moderator"
                           style="border-radius:8px;border:1px solid #e0e0e0;padding:10px 14px;" />
                    <span asp-validation-for="Name" class="text-danger" style="font-size:12px;"></span>
                </div>

                <button type="submit" class="btn w-100"
                        style="background:#18181b;color:white;border-radius:8px;padding:12px;font-size:14px;font-weight:500;">
                    Создать
                </button>
            </form>

            <div style="text-align:center;margin-top:20px;">
                <a asp-action="Index" style="font-size:13px;color:#4f8ef7;text-decoration:none;">← К списку ролей</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}