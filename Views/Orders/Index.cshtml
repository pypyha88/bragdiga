@using praktika.Models
@model List<Order>
@{
    ViewData["Title"] = "Управление заказами";
}

<div style="background:white;border-radius:16px;padding:24px;border:1px solid #f0f0f0;margin-bottom:20px;">
    <div style="display:flex;justify-content:space-between;align-items:center;">
        <h2 style="font-size:1.2rem;font-weight:600;color:#111;margin:0;">Управление заказами</h2>
        <div style="display:flex;gap:8px;font-size:12px;color:#999;">
            <span style="background:#fff7ed;color:#c2410c;padding:3px 10px;border-radius:4px;">Новый: @Model.Count(o => o.Status == "Новый")</span>
            <span style="background:#eff6ff;color:#1d4ed8;padding:3px 10px;border-radius:4px;">Подтверждён: @Model.Count(o => o.Status == "Подтверждён")</span>
            <span style="background:#f0fdf4;color:#16a34a;padding:3px 10px;border-radius:4px;">Выполнен: @Model.Count(o => o.Status == "Выполнен")</span>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div style="background:white;border-radius:16px;padding:60px;text-align:center;color:#999;border:1px solid #f0f0f0;">
        <div style="font-size:2.5rem;margin-bottom:12px;">📦</div>
        <div style="font-size:14px;">Заказов пока нет</div>
    </div>
}
else
{
    @foreach (var order in Model)
    {
        <div style="background:white;border-radius:14px;border:1px solid #f0f0f0;padding:20px;margin-bottom:12px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                <div style="display:flex;align-items:center;gap:12px;">
                    <span style="font-size:14px;font-weight:700;color:#111;">Заказ №@order.IdOrder</span>
                    <span style="font-size:11px;color:#999;">@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                    <span style="font-size:12px;color:#555;">👤 @order.User?.Login</span>
                </div>
                <div style="display:flex;align-items:center;gap:10px;">
                    <span style="background:@(order.Status == "Выполнен" ? "#f0fdf4" : order.Status == "Отменён" ? "#fef2f2" : order.Status == "Подтверждён" ? "#eff6ff" : order.Status == "В доставке" ? "#f5f3ff" : "#fff7ed");
                                         color:@(order.Status == "Выполнен" ? "#16a34a" : order.Status == "Отменён" ? "#dc2626" : order.Status == "Подтверждён" ? "#1d4ed8" : order.Status == "В доставке" ? "#7c3aed" : "#c2410c");
                                         font-size:11px;padding:4px 12px;border-radius:4px;font-weight:500;">
                        @order.Status
                    </span>
                    <span style="font-size:15px;font-weight:700;color:#111;">@order.TotalPrice.ToString("N2") руб</span>
                </div>
            </div>

            <div style="margin-bottom:14px;">
                @foreach (var item in order.Items)
                {
                    <div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid #f5f5f5;font-size:12px;">
                        <span style="color:#555;">@item.Product?.Name × @item.Quantity</span>
                        <span style="color:#111;">@((item.Price * item.Quantity).ToString("N2")) руб</span>
                    </div>
                }
            </div>

            <div style="display:flex;gap:6px;flex-wrap:wrap;">
                @foreach (var status in new[] { "Новый", "Подтверждён", "В доставке", "Выполнен", "Отменён" })
                {
                    <form asp-action="UpdateStatus" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@order.IdOrder" />
                        <input type="hidden" name="status" value="@status" />
                        <button type="submit" style="padding:5px 12px;border-radius:6px;font-size:11px;cursor:pointer;border:1px solid #e0e0e0;
                                           background:@(order.Status == status ? "#18181b" : "white");
                                           color:@(order.Status == status ? "white" : "#555");">
                            @status
                        </button>
                    </form>
                }
            </div>
        </div>
    }
}